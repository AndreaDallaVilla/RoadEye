# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/roadeye

# Server
PORT=3001
NODE_ENV=production

# CORS - IMPORTANTE: Specifichi gli URL client autorizzati (separati da virgola se più di uno)
CLIENT_URL=https://yourdomain.com,https://app.yourdomain.com

# Security - Rate Limiting
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MINUTES=15
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60

# Security - Sessions
AUTH_SESSION_TTL_HOURS=24

# Security - MFA Testing (NON USARE IN PRODUZIONE)
AUTH_MFA_TEST_CODE=000000
AUTH_TEST_OTP_CODE=000000

# Email Configuration (per Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@roadeye.it

# Google Maps
GOOGLE_MAPS_API_KEY=your-api-key
GOOGLE_MAPS_MAP_ID=your-optional-javascript-map-id
GOOGLE_MAPS_LANGUAGE=it
GOOGLE_MAPS_REGION=it
